# ============================================================
# LLM 配置
# ============================================================
# spring.ai.provider: LLM 协议类型（openai-compatible 或 anthropic）
# llm.base-url: LLM 服务的 HTTP 地址（openai-compatible 需要，anthropic 可省略）
# llm.api-key: API 密钥
# llm.model: 聊天模型 ID
# llm.max-tokens: 单次回复最大 token 数量
# llm.context-limit: 模型上下文窗口上限（单位：token）
# ============================================================
spring:
  ai:
    provider: ${SPRING_AI_PROVIDER:openai-compatible}

llm:
  base-url: ${LLM_BASE_URL}
  api-key: ${LLM_API_KEY}
  model: ${LLM_MODEL}
  max-tokens: ${LLM_MAX_TOKENS:4096}
  context-limit: ${LLM_CONTEXT_LIMIT:128000}
